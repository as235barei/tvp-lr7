# Приклад конфігурації сервера. Скопіюйте у server/.env та заповніть значення.
DB_HOST=localhost
DB_PORT=3306
DB_USER=shop
DB_PASSWORD=shoppass
DB_NAME=techshop

PORT=3000
CORS_ORIGIN=http://localhost:5173

# Секрет для підпису JWT — згенеруйте випадковий рядок:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES=7d
